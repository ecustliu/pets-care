# Neon 云端 PostgreSQL 连接串
# 1. 打开 https://neon.tech 注册并创建项目
# 2. 在 Dashboard → Connection details 复制连接串
# 3. 复制本文件为 .env.local 并填入真实地址：
#    cp .env.example .env.local
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# 高德地图 Web 端 Key（门店地图）
# 申请：https://lbs.amap.com/ → 应用管理 → 创建 Key（Web端 JS API）
NEXT_PUBLIC_AMAP_KEY="your-amap-key"
