{
  "name": "pets-care",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "sh -c 'set -a && if [ -f .env.local ]; then . ./.env.local; elif [ -f .env ]; then . ./.env; fi; set +a && prisma db push'",
    "db:studio": "sh -c 'set -a && if [ -f .env.local ]; then . ./.env.local; elif [ -f .env ]; then . ./.env; fi; set +a && prisma studio'"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "prisma": "^6.19.3",
    "typescript": "^5"
  }
}
