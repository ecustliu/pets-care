generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id        String   @id @default(uuid())
  ownerName String
  phone     String
  petName   String
  petType   String
  service   String
  date      String
  time      String
  notes     String   @default("")
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([date, time])
}
