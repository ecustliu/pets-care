generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id        String   @id @default(uuid())
  ownerName String
  phone     String
  petName   String
  petType   String
  packageType String
  date      String
  time      String
  notes     String   @default("")
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([date, time])
}

model Review {
  id            String   @id @default(uuid())
  authorName    String
  petInfo       String
  avatar        String   @default("🐾")
  stars         Int
  content       String
  packageType   String?
  petType       String?
  status        String   @default("pending")
  featured      Boolean  @default(false)
  featuredOrder Int      @default(0)
  bookingId     String?  @unique
  createdAt     DateTime @default(now())

  @@index([status, featured, featuredOrder])
  @@index([createdAt])
}
